# Auth.js — https://authjs.dev/getting-started/deployment
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3002

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In — https://developer.apple.com/
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Email magic link (SMTP)
EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
EMAIL_FROM=noreply@thailand-villa-rent.com

# Booking request notifications
BOOKING_REQUEST_TO=reservations@thailand-villa-rent.com

# Comma-separated admin emails allowed to open /admin
ADMIN_EMAILS=owner@example.com
